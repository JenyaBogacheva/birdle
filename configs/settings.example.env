# Backend environment variables
# Copy this file to .env.local in the project root and adjust as needed

# OpenAI API Key (required for LLM integration)
OPENAI_API_KEY=your-openai-api-key-here

# eBird API Token (required for MCP integration)
EBIRD_TOKEN=your-ebird-token-here

# Frontend base URL (for CORS configuration)
FRONTEND_BASE_URL=http://localhost:5173

# App settings
APP_NAME=Bird-ID MVP
DEBUG=true
