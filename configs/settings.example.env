# Backend environment variables
# Copy this file to .env.local in the project root and adjust as needed

# Anthropic API Key (required for Claude Sonnet agent)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Tavily API Key (required for web search)
TAVILY_API_KEY=tvly-your-tavily-api-key-here

# eBird API Token (required for regional bird data)
EBIRD_TOKEN=your-ebird-token-here

# Frontend base URL (for CORS configuration)
FRONTEND_BASE_URL=http://localhost:5173

# App settings
APP_NAME=Birdle AI
DEBUG=true
